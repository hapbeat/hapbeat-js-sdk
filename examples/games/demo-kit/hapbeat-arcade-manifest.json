{
  "schema_version": "2.0.0",
  "version": "0.1.0",
  "name": "hapbeat-arcade",
  "description": "Hapbeat Arcade デモ（ブラウザ + helper）用のプレースホルダ Kit。各 event の clip / intensity は studio の showcase-kit から流用した仮置き値。最終調整はユーザーが行う前提（examples/games/TUNING.md 参照）。",
  "author": "Hapbeat",
  "created_at": "2026-06-08T00:00:00.000Z",
  "target_device": {
    "firmware_version_min": "0.0.2",
    "volume_level": 6,
    "volume_wiper": 70,
    "volume_steps": 10
  },
  "events": {
    "hapbeat-arcade.maze_bump": {
      "clip": "z5_shot_light.wav",
      "description": "迷路: 見えない壁に接触。実際の gain は接触速度でスケールする (0.25-1.0)。",
      "parameters": { "intensity": 0.5, "loop": false }
    },
    "hapbeat-arcade.maze_goal": {
      "clip": "z2_door_unlock.wav",
      "description": "迷路: ゴール到達のポジティブフィードバック。",
      "parameters": { "intensity": 0.6, "loop": false }
    },
    "hapbeat-arcade.maze_fail": {
      "clip": "z2_door_slam.wav",
      "description": "迷路: Expert の即死モードで壁に当たった時のフェイル。",
      "parameters": { "intensity": 0.7, "loop": false }
    },
    "hapbeat-arcade.rhythm_cue": {
      "clip": "z4_slider_tick.wav",
      "description": "リズム: 各拍の触覚キュー（=触覚メトロノーム）。叩くべき瞬間に発火。",
      "parameters": { "intensity": 0.45, "loop": false }
    },
    "hapbeat-arcade.rhythm_hit": {
      "clip": "z1_pin_hit.wav",
      "description": "リズム: 判定成功の確認フィードバック。",
      "parameters": { "intensity": 0.5, "loop": false }
    },
    "hapbeat-arcade.rhythm_combo": {
      "clip": "z5_tar_hit_light.wav",
      "description": "リズム: コンボ節目（10 コンボごと）の強めフィードバック。",
      "parameters": { "intensity": 0.55, "loop": false }
    },
    "hapbeat-arcade.hot_pulse": {
      "clip": "z1_pin_hit.wav",
      "description": "宝探し: ガイガーカウンタ式の近接パルス。gain とパルス間隔がターゲットへの近さでスケールする。",
      "parameters": { "intensity": 0.4, "loop": false }
    },
    "hapbeat-arcade.hot_found": {
      "clip": "z5_tar_hit_heavy.wav",
      "description": "宝探し: ターゲット発見の強い当たりフィードバック。",
      "parameters": { "intensity": 0.6, "loop": false }
    },
    "hapbeat-arcade.hot_timeout": {
      "clip": "z2_door_slam.wav",
      "description": "宝探し: 制限時間切れのフェイル。",
      "parameters": { "intensity": 0.7, "loop": false }
    },
    "hapbeat-arcade.reflex_go": {
      "clip": "z1_pin_hit.wav",
      "description": "反応速度: GO 合図。視覚 OFF でも気づける強く鋭い単発。",
      "parameters": { "intensity": 0.75, "loop": false }
    },
    "hapbeat-arcade.reflex_foul": {
      "clip": "z2_door_slam.wav",
      "description": "反応速度: お手つき（フライング）。",
      "parameters": { "intensity": 0.6, "loop": false }
    },
    "hapbeat-arcade.reflex_win": {
      "clip": "z5_tar_hit_heavy.wav",
      "description": "反応速度: 全ラウンド完了の締め。",
      "parameters": { "intensity": 0.6, "loop": false }
    }
  },
