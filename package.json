{
  "name": "@hapbeat/sdk",
  "version": "0.2.0",
  "description": "JavaScript/TypeScript SDK for driving Hapbeat haptic devices (direct UDP in Node and React Native, hapbeat-helper WebSocket in the browser)",
  "type": "module",
  "license": "MIT",
  "author": "Hapbeat",
  "homepage": "https://devtools.hapbeat.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hapbeat/hapbeat-js-sdk.git"
  },
  "bugs": "https://github.com/hapbeat/hapbeat-js-sdk/issues",
  "keywords": ["hapbeat", "haptics", "udp", "osc", "webxr", "three.js", "vr", "react-native", "creative-coding"],
  "main": "./dist/node.js",
  "module": "./dist/node.js",
  "types": "./dist/node.d.ts",
  "exports": {
    ".": {
      "node": { "types": "./dist/node.d.ts", "default": "./dist/node.js" },
      "react-native": { "types": "./dist/react-native.d.ts", "default": "./dist/react-native.js" },
      "browser": { "types": "./dist/browser.d.ts", "default": "./dist/browser.js" },
      "default": { "types": "./dist/browser.d.ts", "default": "./dist/browser.js" }
    }
  },
  "sideEffects": false,
  "publishConfig": { "access": "public" },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test",
    "dev": "npm run build && node scripts/dev-server.mjs",
    "serve": "node scripts/dev-server.mjs --no-watch",
    "prepublishOnly": "npm run build"
  },
  "engines": { "node": ">=18" },
  "peerDependencies": {
    "react-native-udp": ">=4"
  },
  "peerDependenciesMeta": {
    "react-native-udp": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.5"
  }
}
